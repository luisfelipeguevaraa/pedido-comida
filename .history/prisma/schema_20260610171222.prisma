generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Menu {
  id    Int      @id @default(autoincrement())
  fecha DateTime
  plato String
}

model Order {
  id             Int      @id @default(autoincrement())
  nombre         String
  telefono       String
  lugarRecepcion String
  cantidad       Int
  menuIds        String
  createdAt      DateTime @default(now())
}
